{
  "family": "innovatech-frontend",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "256",
  "memory": "512",
  "executionRoleArn": "arn:aws:iam::447578577047:role/LabRole",
  "taskRoleArn": "arn:aws:iam::447578577047:role/LabRole",
  "containerDefinitions": [
    {
      "name": "frontend",
      "image": "447578577047.dkr.ecr.us-east-1.amazonaws.com/innovatech/frontend:latest",
      "portMappings": [
        {
          "containerPort": 80,
          "protocol": "tcp"
        }
      ],
      "essential": true,
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/innovatech-frontend",
          "awslogs-region": "us-east-1",
          "awslogs-stream-prefix": "ecs",
          "awslogs-create-group": "true"
        }
      }
    }
  ]
}